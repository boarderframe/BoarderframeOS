class PresenceStatus(Enum):
    ONLINE = "online"
    BUSY = "busy"
    AWAY = "away"
    OFFLINE = "offline"


class MessageFormat(Enum):
    TEXT = "text"
    MARKDOWN = "markdown"
    CODE = "code"
    FILE = "file"
    VOICE = "voice"


class ChannelType(Enum):
    DIRECT = "direct"
    DEPARTMENT = "department"
    TOPIC = "topic"
    BROADCAST = "broadcast"


class ChatMessage(BaseModel):
    channel: Optional[str] = None
