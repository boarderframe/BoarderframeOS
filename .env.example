# BoarderframeOS Environment Configuration
# Copy this file to .env and update the values

# Database Configuration
POSTGRES_PASSWORD=boarderframe_secure_2025
POSTGRES_PORT=5434
DATABASE_URL=postgresql://boarderframe:boarderframe_secure_2025@localhost:5434/boarderframeos

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Application Configuration
APP_PORT=8000
ENVIRONMENT=development

# Database Admin Tools
PGADMIN_EMAIL=admin@boarderframeos.local
PGADMIN_PASSWORD=admin_secure_2025
PGADMIN_PORT=8080

ADMINER_PORT=8081

REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin_secure_2025
REDIS_COMMANDER_PORT=8082

# Nginx Configuration (if using nginx profile)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here
API_KEY_SECRET=your_api_key_secret_here

# Monitoring
ENABLE_MONITORING=true
LOG_LEVEL=INFO