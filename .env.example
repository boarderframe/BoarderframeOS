# BoarderframeOS Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL=postgresql://boarderframe:boarderframe_secure_2025@localhost:5434/boarderframeos
POSTGRES_PASSWORD=boarderframe_secure_2025
POSTGRES_PORT=5434

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# API Keys (Development Phase - Replace with your keys)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here
GROQ_API_KEY=your_groq_key_here

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Corporate HQ Settings
CORP_HQ_PORT=8888
CORP_HQ_HOST=0.0.0.0

# MCP Server Ports
MCP_REGISTRY_PORT=8000
MCP_FILESYSTEM_PORT=8001
MCP_DATABASE_SQLITE_PORT=8004
MCP_LLM_PORT=8005
MCP_PAYMENT_PORT=8006
MCP_ANALYTICS_PORT=8007
MCP_CUSTOMER_PORT=8008
MCP_REGISTRY_PORT=8009
MCP_DATABASE_POSTGRES_PORT=8010

# Agent Configuration
MAX_AGENTS=120
AGENT_MEMORY_LIMIT=1000
AGENT_TIMEOUT=300

# Cost Management
COST_OPTIMIZATION_ENABLED=true
COST_ALERT_THRESHOLD=100
MONTHLY_BUDGET_LIMIT=500

# Security
SECRET_KEY=generate_a_secure_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Docker Admin Tools (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_secure_2025
PGADMIN_PORT=8080

ADMINER_PORT=8081

REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin_secure_2025
REDIS_COMMANDER_PORT=8082